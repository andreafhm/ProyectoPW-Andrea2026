{
  "name": "proyecto-3",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js --config cucumber.js",
    "test:smoke": "cross-env TAGS='@smoke' cucumber-js --config cucumber.js",
    "test:login": "cross-env TAGS='@login' cucumber-js --config cucumber.js",
    "clean": "rimraf reports",
    "test:chromium": "cross-env BROWSER=chromium cucumber-js --config cucumber.js",
    "test:firefox": "cross-env BROWSER=firefox cucumber-js --config cucumber.js",
    "test:webkit": "cross-env BROWSER=webkit cucumber-js --config cucumber.js",
    "test:all-browsers": "npm run clean && npm run test:chromium && npm run test:firefox && npm run test:webkit",
    "report": "node generate-report.js",
    "test:all-report": "npm run test:all-browsers && npm run report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.3",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.2",
    "cross-env": "^10.1.0",
    "multiple-cucumber-html-reporter": "^3.10.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
