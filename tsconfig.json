        "target": "ES2020",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "rootDir": "./",
        "types": ["node"]
    },
    "include": [
        "tests/**/*.ts",
        "cucumber.js"
